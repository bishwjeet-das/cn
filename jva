import java.util.Scanner;


abstract class ThreeDObject {
    
    protected double dim1;
    protected double dim2;
    protected double dim3;

    
    public ThreeDObject(double d1, double d2, double d3) {
        this.dim1 = d1;
        this.dim2 = d2;
        this.dim3 = d3;
    }

    
    public abstract double volume();
    public abstract double wholeSurfaceArea();
}


class Box extends ThreeDObject {

    public Box(double length, double width, double height) {
        super(length, width, height);
    }

    @Override
    public double volume() {
        return dim1 * dim2 * dim3;
    }

    @Override
    public double wholeSurfaceArea() {
        return 2 * (dim1 * dim2 + dim2 * dim3 + dim1 * dim3);
    }
}


class Cube extends ThreeDObject {

    public Cube(double side) {
        super(side, side, side);
    }

    @Override
    public double volume() {
        return dim1 * dim1 * dim1;
    }

    @Override
    public double wholeSurfaceArea() {
        return 6 * dim1 * dim1;
    }
}


class Cylinder extends ThreeDObject {

    public Cylinder(double radius, double height) {
        super(radius, height, 0);
    }

    @Override
    public double volume() {
        return Math.PI * dim1 * dim1 * dim2;
    }

    @Override
    public double wholeSurfaceArea() {
        return 2 * Math.PI * dim1 * (dim1 + dim2);
    }
}


class Cone extends ThreeDObject {

    public Cone(double radius, double height) {
        super(radius, height, 0);
    }

    @Override
    public double volume() {
        return (1.0 / 3) * Math.PI * dim1 * dim1 * dim2;
    }

    @Override
    public double wholeSurfaceArea() {
        double slantHeight = Math.sqrt(dim1 * dim1 + dim2 * dim2);
        return Math.PI * dim1 * (dim1 + slantHeight);
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice;

        do {
            System.out.println("\n--- 3D Object Menu ---");
            System.out.println("1. Box");
            System.out.println("2. Cube");
            System.out.println("3. Cylinder");
            System.out.println("4. Cone");
            System.out.println("5. Exit");
            System.out.print("Enter your choice: ");
            choice = sc.nextInt();

            ThreeDObject obj = null;

            switch (choice) {
                case 1:
                    System.out.print("Enter length, width, height: ");
                    double l = sc.nextDouble();
                    double w = sc.nextDouble();
                    double h = sc.nextDouble();
                    obj = new Box(l, w, h);
                    break;

                case 2:
                    System.out.print("Enter side: ");
                    double s = sc.nextDouble();
                    obj = new Cube(s);
                    break;

                case 3:
                    System.out.print("Enter radius and height: ");
                    double r = sc.nextDouble();
                    double ch = sc.nextDouble();
                    obj = new Cylinder(r, ch);
                    break;

                case 4:
                    System.out.print("Enter radius and height: ");
                    double cr = sc.nextDouble();
                    double hh = sc.nextDouble();
                    obj = new Cone(cr, hh);
                    break;

                case 5:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

            if (obj != null) {
                System.out.println("Volume = " + obj.volume());
                System.out.println("Surface Area = " + obj.wholeSurfaceArea());
            }

        } while (choice != 5);

        sc.close();
    }
}














package Pack1;

public interface Department {

    // Attributes (by default: public static final)
    String depName = "CSE";
    String depHead = "Dr. Smith";

    // Abstract methods (by default: public abstract)
